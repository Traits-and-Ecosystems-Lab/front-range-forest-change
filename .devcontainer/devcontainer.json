{
  "name": "ESIIL STARS 2026 – Front Range Forest Change",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "vscode",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-toolsai.vscode-jupyter-cell-tags",
        "ms-toolsai.vscode-jupyter-slideshow",
        "GitHub.copilot"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/conda/envs/esiil-stars/bin/python",
        "jupyter.notebookFileRoot": "${workspaceFolder}",
        "python.terminal.activateEnvironment": true,
        "editor.formatOnSave": true,
        "notebook.formatOnSave.enabled": true
      }
    }
  },

  "forwardPorts": [8888, 5006],

  "postCreateCommand": "echo '✅ Environment ready — run: conda activate esiil-stars' && python --version && gdalinfo --version"
}
